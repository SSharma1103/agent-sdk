{
  "name": "@shivamsharma11/agent-sdk",
  "version": "0.1.1",
  "description": "Framework-agnostic TypeScript SDK for building agents, agent teams, tools, pipelines, and dev UI workflows.",
  "license": "MIT",
  "type": "module",
  "author": "Shivam Sharma",
  "homepage": "https://github.com/SSharma1103/agent-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SSharma1103/agent-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/SSharma1103/agent-sdk/issues"
  },
  "keywords": [
    "agents",
    "ai",
    "agent-sdk",
    "agent-teams",
    "llm",
    "orchestration",
    "typescript",
    "tools"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/sdk",
    "README.md",
    "LICENSE",
    "API_REFERENCE.md"
  ],
  "main": "dist/sdk/index.js",
  "types": "dist/sdk/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js",
      "default": "./dist/sdk/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "build:web": "vite build --config examples/dev-ui/web/vite.config.ts",
    "dev:web": "npm run build && npm run build:web && node dist/examples/dev-ui/server/example.js",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "npm run build",
    "test": "npm run build && node --test tests/*.test.mjs"
  },
  "peerDependencies": {
    "@prisma/client": ">=5",
    "zod": ">=3"
  },
  "peerDependenciesMeta": {
    "@prisma/client": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
