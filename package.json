{
  "name": "@myui/agent-sdk",
  "version": "0.1.0",
  "description": "Stack-agnostic AI orchestration SDK extracted from the automations architecture.",
  "license": "MIT",
  "type": "module",
  "main": "dist/sdk/index.js",
  "types": "dist/sdk/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js",
      "default": "./dist/sdk/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "build:web": "vite build --config examples/dev-ui/web/vite.config.ts",
    "dev:web": "npm run build && npm run build:web && node dist/examples/dev-ui/server/example.js",
    "test": "npm run build && node --test tests/*.test.mjs"
  },
  "peerDependencies": {
    "@prisma/client": ">=5",
    "zod": ">=3"
  },
  "peerDependenciesMeta": {
    "@prisma/client": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^5.8.0",
    "vite": "^8.0.11"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
