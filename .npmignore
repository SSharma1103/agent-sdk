# The published package is also constrained by package.json "files".
# Keep this ignore file conservative for older npm tooling.

# Source and examples
sdk/
examples/
tests/
docs/
.github/
.changeset/

# Development config
tsconfig.json
eslint.config.js
.prettierrc.json
.prettierignore
ARCHITECTURE.md
CONTRIBUTING.md
CODE_OF_CONDUCT.md
SECURITY.md
SUPPORT.md
ROADMAP.md
CHANGELOG.md

# Dependencies, caches, and build artifacts outside the SDK package
node_modules/
dist/examples/
examples/dev-ui/web/dist/
.npm/
.pnpm-store/
.yarn/
.turbo/
.cache/
coverage/

# Environment and local config
.env
.env.*
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Git/editor/tooling metadata
.git/
.gitignore
.claude/
.codex/
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp
*.swo

# Package artifacts
!dist/sdk/
!dist/sdk/**
!README.md
!LICENSE
!API_REFERENCE.md
!package.json
